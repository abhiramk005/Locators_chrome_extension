{
  "manifest_version": 3,
  "name": "Robot Locator Grabber for AI",
  "version": "1.7",
  "permissions": ["sidePanel", "activeTab", "scripting"],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel/panel.html" },
  "action": { "default_title": "Open Grabber" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["utils/dom-utils.js", "content.js"],
    "run_at": "document_start"
  }]
}